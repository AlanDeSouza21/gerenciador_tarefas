@model List<Model_index>
@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1>Gerenciador de Tarefas</h1>
    <h3>Comece por aqui</h3>
    <br />

    <!-- O botão deve ficar fora da tabela ou em uma estrutura válida -->
    <div class="mb-3">
        <button type="button" class="btn btn-primary" onclick="toggleCadastro()">
            Criar Novo Registro
        </button>
    </div>
    <form asp-controller="Home" asp-action="Index" method="post"> <!-- declaração controller, action e método de requisição -->
        <table class="table table-hover">
            <thead>
                <tr>
                    <th scope="col">Conclusão</th>
                    <th scope="col">Indice</th>
                    <th scope="col">Tarefa</th>
                    <th scope="col">Data</th>
                    <th scope="col">Horário início</th>
                    <th scope="col">Horário fim</th>
                    <th scope="col">Prazo final</th>
                    <th scope="col">Ações</th>
                </tr>
            </thead>

            <tbody>
                <!-- Registro Exemplo (Depois você fará o foreach aqui) -->
                @if(Model != null && Model.Any()) // CONDIÇÃO: se model for diferente de nulo e model tiver algo
                {
                    foreach(Model_index dados in Model) 
                    {// Loop percorre a model e repete até finalizar o carregamento dos dados
                        <tr style="display: table-row">
                            <td><input class="form-check-input" type="checkbox"></td>
                            <th scope="row">@dados.Id</th>
                            <td>@dados.Tarefa</td>
                            <td>@dados.Data</td>
                            <td>@dados.Horario_inicio</td>
                            <td>@dados.Horario_fim</td>
                            <td>@dados.Prazo_final</td>
                            <td>
                                <a role="button" class="btn btn-primary btn-sm" asp-route-id="@dados.Id" onclick="toggle_Editar(this)">Editar</a>
                                <a role="button" class="btn btn-danger btn-sm" asp-route-id="@dados.Id">Apagar</a>
                            </td>
                        </tr>
                        @await Html.PartialAsync("_LinhaEditar", new Model_index())
                    }
                }
                <!-- PARTIAL VIEW (_LinhaCadastro) responsável por Linha de cadastro -->
                @await Html.PartialAsync("_LinhaCadastro", new Model_index())
                
            </tbody>


        </table>

    </form>
</div>

@section Scripts {
    <script>
        function toggleCadastro() {
            const linha = document.getElementById("linhaCadastro");
            // Se estiver escondido, mostra. Se estiver visível, esconde.
            if (linha.style.display === "table-row") {
                linha.style.display = "none";
            } else {
                linha.style.display = "table-row";
            }
            console.log("apertou novo cadastro")
        }

        function toggle_Editar(botao) {
            // encontra a linha mais próxima (ex: mesma linha da tabela)
            const linha_editar = botao.closest("tr").nextElementSibling;

            if (linha_editar.style.display === "none") {
                linha_editar.style.display = "table-row";
            } else {
                linha_editar.style.display = "none";
            }
            console.log(linha_editar)
        }
        /*
        function salvarNovoRegistro() {
            // Aqui você adiciona a lógica para pegar os valores e enviar ao Controller
            alert("Botão Salvar clicado! Agora é só implementar o envio dos dados.");
        }*/
    </script>
}
</div>
