@model Model_index

<tr id="linhaCadastro" style="display: none; background-color: #f8f9fa;">
    <td>
        <input class="form-check-input" type="checkbox" name="novoConcluido">
    </td>
    <td>?</td>
    <td>
        <input type="text" asp-for="Tarefa" class="form-control form-control-sm" />
    </td>
    <td>
        <input type="date" asp-for="Data" class="form-control form-control-sm" />
    </td>
    <td>
        <input type="time" asp-for="Horario_inicio" class="form-control form-control-sm" />
    </td>
    <td>
        <input type="time" asp-for="Horario_fim" class="form-control form-control-sm" />
    </td>
    <td>
        <input type="date" asp-for="Prazo_final" class="form-control form-control-sm" />
    </td>
    <td>
        <button type="submit" class="btn btn-success btn-sm">Registrar</button>
        <button type="button" class="btn btn-secondary btn-sm" onclick="toggleCadastro()">Cancelar</button>
    </td>
</tr>
